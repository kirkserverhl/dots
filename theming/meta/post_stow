#!/usr/bin/env bash
set -euo pipefail

# Install pywalfox extension (only needed once per user)
# This allows matugen-generated colors to be applied to Firefox
pywalfox install || true

# Set KDE icon theme for Dolphin and other KDE6 apps
if command -v kwriteconfig6 >/dev/null 2>&1; then
    kwriteconfig6 --file kdeglobals --group General --key IconTheme material-actions
fi

# Set GTK icon theme for LibreOffice and other GTK apps
if command -v gsettings >/dev/null 2>&1; then
    gsettings set org.gnome.desktop.interface icon-theme 'material-actions'
fi

# --- Generate initial colors with matugen using a default wallpaper ---
# This ensures new machines get a working color scheme even before the user sets a real wallpaper.
if command -v matugen >/dev/null 2>&1; then
    # Try to find the dots directory relative to this script
    SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
    DEFAULT_WALLPAPER_DIR="$SCRIPT_DIR/theming/default-wallpaper"

    # Pick the first image file in the default-wallpaper directory (if any)
    DEFAULT_WALL=$(find "$DEFAULT_WALLPAPER_DIR" -type f \( -iname '*.jpg' -o -iname '*.jpeg' -o -iname '*.png' -o -iname '*.webp' \) 2>/dev/null | head -n 1)

    if [[ -n "$DEFAULT_WALL" ]]; then
        echo "Running matugen with default wallpaper: $DEFAULT_WALL"
        if matugen image "$DEFAULT_WALL"; then
            echo "Matugen finished with default wallpaper."

            # Also set the wallpaper using waypaper so the desktop looks correct on first boot
            if command -v waypaper >/dev/null 2>&1; then
                echo "Setting wallpaper with waypaper..."
                waypaper --wallpaper "$DEFAULT_WALL" || echo "Warning: waypaper failed to set the default wallpaper."
            else
                echo "waypaper not found — skipping wallpaper setting step."
            fi
        else
            echo "Warning: matugen failed with default wallpaper"
        fi
    else
        echo "No default wallpaper found in $DEFAULT_WALLPAPER_DIR — skipping initial matugen + waypaper run."
        echo "Drop a wallpaper image there for automatic color generation + wallpaper on new machines."
    fi
else
    echo "matugen not found — skipping initial color generation."
fi
