#!/usr/bin/env bash
set -euo pipefail

: "${DOTDIR:="$HOME/.dots"}"
DOTCTL_LIB="${DOTCTL_LIB:-$DOTDIR/dotctl/.local/lib/dotctl/lib}"

source "${DOTCTL_LIB}/lib.sh"
source "${DOTCTL_LIB}/install.sh"
source "${DOTCTL_LIB}/track.sh"
source "${DOTCTL_LIB}/sync.sh"
source "${DOTCTL_LIB}/upgrade.sh"
source "${DOTCTL_LIB}/update.sh"

show_help() {
    cat <<'EOF'
dotctl - manage your dotfiles

Usage:
EOF
    cmd_install_help
    cmd_track_help
    cmd_add_help
    cmd_upgrade_help
    cmd_sync_help
    cmd_update_help
    cat <<'EOF'
  dotctl ls
  dotctl list
  dotctl help

Commands:
  install     Install one or more packages
  track       Track an existing config into a package
  add         Alias for track
  upgrade     Reinstall all installed packages (no repo sync)
  sync        Pull the dotfiles repo safely (ff-only, clean state required)
  update      Sync the repo then upgrade installed packages
  ls          List installed and not installed packages
  list        Alias for ls
  help        Show this help

Global options:
  --force     Reinstall packages even when the tracked commit is unchanged
  -y          Answer yes to confirmation prompts
EOF
}

if [[ $# -lt 1 ]]; then
    show_help
    exit 1
fi

DOTCTL_FORCE="false"
YES="false"

cmd=""
declare -a cmd_args=()
parse_globals="true"

while [[ $# -gt 0 ]]; do
    case "$1" in
        --)
            parse_globals="false"
            shift
            continue
            ;;
        --force)
            if [[ "$parse_globals" == "true" ]]; then
                DOTCTL_FORCE="true"
                shift
                continue
            fi
            ;;
        -y)
            if [[ "$parse_globals" == "true" ]]; then
                YES="true"
                shift
                continue
            fi
            ;;
    esac

    if [[ -z "$cmd" ]]; then
        cmd="$1"
    else
        cmd_args+=("$1")
    fi
    shift
done

export DOTCTL_FORCE
export YES

[[ -n "$cmd" ]] || die "Specify a command."
set -- "${cmd_args[@]}"

case "$cmd" in
    install)
        [[ $# -gt 0 ]] || die "Specify packages or 'all'"

        if [[ "$1" == "all" ]]; then
            mapfile -t requested_pkgs < <(
                find "$DOTDIR" -mindepth 1 -maxdepth 1 -type d \
                    -not -name ".*" -not -name "_*" \
                    | xargs -n1 basename
            )
        else
            requested_pkgs=("$@")
        fi

        INSTALL_PLAN=()
        RESOLVED_PACKAGES=()
        VISITING_PACKAGES=()

        for requested_pkg in "${requested_pkgs[@]}"; do
            resolve_pkg_plan "$requested_pkg"
        done

        echo "Installing packages: ${INSTALL_PLAN[*]}"
        for requested_pkg in "${INSTALL_PLAN[@]}"; do
            perform_install_pkg "$requested_pkg"
        done
        ;;
    track|add)
        [[ $# -ge 2 ]] || die "Usage: dotctl $cmd [package] [...paths]"
        process_track_pkg "$@"
        ;;
    help|--help|-h)
        show_help
        ;;
    upgrade)
        if [[ "${1:-}" == "--no-pull" ]]; then
            echo "error: --no-pull is no longer supported for upgrade." >&2
            echo "upgrade no longer syncs the repo; use sync or update instead." >&2
            exit 1
        fi
        process_upgrade_pkg
        ;;
    sync)
        process_sync
        ;;
    update)
        process_update_pkg
        ;;
    ls|list)
        mapfile -t all_pkgs < <(
            find "$DOTDIR" -mindepth 1 -maxdepth 1 -type d \
                -not -name ".*" -not -name "_*" | xargs -n1 basename
        )

        echo "Installed configs:"
        while read -r pkg_file; do
            pkg=$(basename "$pkg_file")
            pkg=${pkg%.commit}
            echo "$pkg"
        done < <(find "$DATADIR" -type f -name '*.commit')

        echo
        echo "Not installed:"
        for pkg in "${all_pkgs[@]}"; do
            [[ -f "$DATADIR/$pkg.commit" ]] && continue
            echo "$pkg"
        done
        ;;
    *)
        echo "Unknown command: $cmd"
        show_help
        exit 1
        ;;
esac
