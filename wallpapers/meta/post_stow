#!/usr/bin/env bash
set -euo pipefail

echo "==> wallpapers post-stow"

if [ -L "$HOME/Pictures/Wallpapers" ]; then
    echo "Symlink verified: ~/Pictures/Wallpapers -> $(readlink -f "$HOME/Pictures/Wallpapers")"
else
    echo "Warning: ~/Pictures/Wallpapers is not a symlink."
    echo "This usually means 'migrate.sh wallpapers' has not been run yet,"
    echo "or it failed because 'stow' was not installed."
    echo ""
    echo "To fix: Run from the dots directory:"
    echo "  ./migrate.sh wallpapers"
fi

# Optional: You can add any post-processing here later
# (e.g. regenerating a wallpaper cache, notifying waypaper, etc.)

echo "Wallpapers package deployed."
