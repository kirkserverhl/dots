#!/usr/bin/env bash
set -euo pipefail

if ! command -v brightnessctl >/dev/null 2>&1; then
  echo "brightnessctl is required" >&2
  exit 1
fi

if ! command -v qs >/dev/null 2>&1; then
  echo "qs is required" >&2
  exit 1
fi

usage() {
  echo "Usage: qs-brightness up [step] | down [step] | set <0-100>" >&2
  exit 1
}

if [[ $# -lt 1 ]]; then
  usage
fi

step=10
if [[ $# -ge 2 ]]; then
  step="$2"
fi

case "$1" in
  up)
    brightnessctl set "+${step}%" >/dev/null
    ;;
  down)
    brightnessctl set "${step}%-" >/dev/null
    ;;
  set)
    if [[ $# -lt 2 ]]; then
      usage
    fi
    brightnessctl set "$2%" >/dev/null
    ;;
  *)
    usage
    ;;
esac

value=$(brightnessctl -m | awk -F, '{print $4}' | tr -d '%')
if [[ -z "$value" ]]; then
  exit 0
fi

qs ipc call brightness setLevel "$value" >/dev/null
qs ipc call brightness refresh >/dev/null
