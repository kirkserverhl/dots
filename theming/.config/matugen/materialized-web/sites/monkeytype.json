{
    "version": 1,
    "match": [
        "*://monkeytype.com/*"
    ],
    "rules": [
        {
            "selector": ":root",
            "important": true,
            "set": {
                "--color-bg": "var(--mat-surface)",
                "--bg-color": "var(--mat-surface)",
                "--color-text": "var(--mat-on-surface)",
                "--text-color": "var(--mat-on-surface)",
                "--color-main": "var(--mat-primary)",
                "--main-color": "var(--mat-primary)",
                "--caret-color": "var(--mat-primary)",
                "--color-sub": "var(--mat-on-surface-variant)",
                "--sub-color": "var(--mat-on-surface-variant)",
                "--color-sub-alt": "var(--mat-surface-container-low)",
                "--sub-alt-color": "var(--mat-surface-container-low)",
                "--color-error": "var(--mat-error)",
                "--error-color": "var(--mat-error)",
                "--colorful-error-color": "var(--mat-error)",
                "--colorful-error-extra-color": "color-mix(in srgb, var(--mat-error) 70%, black)",
                "--error-extra-color": "color-mix(in srgb, var(--mat-error) 70%, black)",
                "--ss-bg-color": "var(--mat-surface-container-high)",
                "--ss-primary-color": "var(--mat-primary)",
                "--ss-focus-color": "var(--mat-primary)",
                "--ss-font-color": "var(--mat-on-surface)",
                "--ss-font-placeholder-color": "var(--mat-on-surface-variant)",
                "--ss-border-color": "var(--mat-outline-variant)",
                "--ss-border-radius": "4px",
                "--ss-disabled-color": "var(--mat-outline-variant)",
                "--ss-success-color": "var(--mat-secondary)",
                "--ss-error-color": "var(--mat-error)",
                "--ss-highlight-color": "color-mix(in srgb, var(--mat-primary) 70%, white)",
                "--balloon-color": "var(--mat-surface-container-high)",
                "--balloon-text-color": "var(--mat-on-surface)",
                "--tw-ring-offset-color": "var(--mat-surface)",
                "--current-color": "var(--mat-primary)",
                "--correct-letter-color": "var(--mat-on-surface)",
                "--incorrect-letter-color": "var(--mat-error)",
                "--untyped-letter-color": "color-mix(in srgb, var(--mat-on-surface) 35%, transparent)",
                "--extra-letter-color": "var(--mat-error)",
                "--crt-main-color-glow": "color-mix(in srgb, var(--mat-primary) 20%, transparent)",
                "--crt-caret-color-glow": "color-mix(in srgb, var(--mat-primary) 20%, transparent)",
                "--crt-sub-color-glow": "color-mix(in srgb, var(--mat-on-surface-variant) 20%, transparent)",
                "--crt-text-color-glow": "color-mix(in srgb, var(--mat-on-surface) 20%, transparent)",
                "--crt-sub-alt-color-glow": "color-mix(in srgb, var(--mat-surface-container-low) 20%, transparent)",
                "--crt-error-color-glow": "color-mix(in srgb, var(--mat-error) 20%, transparent)",
                "--crt-bg-color-stripe": "color-mix(in oklab, black 50%, var(--mat-surface))",
                "--crt-bg-color-shine": "color-mix(in oklab, var(--mat-primary) 5%, var(--mat-surface))"
            }
        },
        {
            "selector": "#words",
            "important": true,
            "set": {
                "--correct-letter-color": "var(--mat-on-surface)",
                "--untyped-letter-color": "color-mix(in srgb, var(--mat-on-surface) 35%, transparent)",
                "--incorrect-letter-color": "var(--mat-error)",
                "--extra-letter-color": "var(--mat-error)",
                "--current-color": "var(--mat-primary)"
            }
        },
        {
            "selector": "#words.colorfulMode",
            "important": true,
            "set": {
                "--correct-letter-color": "var(--mat-primary)",
                "--untyped-letter-color": "color-mix(in srgb, var(--mat-on-surface) 35%, transparent)",
                "--incorrect-letter-color": "var(--mat-error)",
                "--extra-letter-color": "color-mix(in srgb, var(--mat-error) 70%, black)"
            }
        },
        {
            "selector": "#words.flipped",
            "important": true,
            "set": {
                "--correct-letter-color": "color-mix(in srgb, var(--mat-on-surface) 35%, transparent)",
                "--untyped-letter-color": "var(--mat-on-surface)",
                "--incorrect-letter-color": "var(--mat-error)",
                "--extra-letter-color": "color-mix(in srgb, var(--mat-error) 70%, black)"
            }
        }
    ]
}
