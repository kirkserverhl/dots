#!/usr/bin/env bash
# Launcher for the dots welcome/setup tool

# Try to find the dots directory (portable)
if [[ -d "$HOME/.dots/setup" ]]; then
    DOTS_DIR="$HOME/.dots"
else
    # Fallback: walk up from this script's location
    SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    # Try common locations relative to the launcher
    if [[ -d "$SCRIPT_DIR/../../../setup" ]]; then
        DOTS_DIR="$(cd "$SCRIPT_DIR/../../.." && pwd)"
    elif [[ -d "$SCRIPT_DIR/../../../../setup" ]]; then
        DOTS_DIR="$(cd "$SCRIPT_DIR/../../../.." && pwd)"
    else
        echo "Error: Could not locate dots repository." >&2
        exit 1
    fi
fi

exec "$DOTS_DIR/setup/welcome.sh" "$@"
