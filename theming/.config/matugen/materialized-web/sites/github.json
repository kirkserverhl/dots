{
    "version": 1,
    "match": [
        "*://github.com/*"
    ],
    "rules": [
        {
            "selector": "html[data-color-mode=\"dark\"][data-dark-theme], html[data-color-mode=\"auto\"][data-light-theme=\"dark\"], html[data-color-mode=\"auto\"][data-dark-theme]",
            "important": true,
            "set": {
                "--bgColor-default": "var(--mat-surface)",
                "--bgColor-muted": "var(--mat-surface-container-lowest)",
                "--bgColor-inset": "var(--mat-surface-container-lowest)",
                "--bgColor-emphasis": "var(--mat-surface-container)",
                "--bgColor-disabled": "var(--mat-surface-container-low)",
                "--bgColor-transparent": "transparent",
                "--fgColor-default": "var(--mat-on-surface)",
                "--fgColor-muted": "var(--mat-on-surface-variant)",
                "--fgColor-neutral": "var(--mat-on-surface-variant)",
                "--fgColor-disabled": "var(--mat-on-surface-variant)",
                "--fgColor-onEmphasis": "var(--mat-on-surface)",
                "--borderColor-default": "var(--mat-outline-variant)",
                "--borderColor-muted": "var(--mat-outline-variant)",
                "--borderColor-emphasis": "color-mix(in srgb, var(--mat-outline) 75%, var(--mat-on-surface) 25%)",
                "--borderColor-disabled": "transparent",
                "--borderColor-translucent": "transparent",
                "--overlay-bgColor": "var(--mat-surface-container)",
                "--tooltip-bgColor": "var(--mat-surface-container)",
                "--selection-bgColor": "color-mix(in srgb, var(--mat-primary) 40%, transparent)",
                "--focus-outlineColor": "var(--mat-primary)",
                "--fgColor-accent": "var(--mat-primary)",
                "--fgColor-link": "var(--mat-primary)",
                "--bgColor-accent-emphasis": "color-mix(in srgb, var(--mat-primary) 72%, transparent)",
                "--bgColor-accent-muted": "color-mix(in srgb, var(--mat-primary) 12%, transparent)",
                "--borderColor-accent-emphasis": "var(--mat-primary)",
                "--borderColor-accent-muted": "color-mix(in srgb, var(--mat-primary) 40%, transparent)",
                "--fgColor-success": "var(--mat-primary)",
                "--bgColor-success-emphasis": "var(--mat-primary)",
                "--bgColor-success-muted": "color-mix(in srgb, var(--mat-primary) 18%, transparent)",
                "--borderColor-success-emphasis": "var(--mat-primary)",
                "--borderColor-success-muted": "color-mix(in srgb, var(--mat-primary) 45%, transparent)",
                "--fgColor-danger": "var(--mat-error)",
                "--bgColor-danger-emphasis": "var(--mat-error)",
                "--bgColor-danger-muted": "color-mix(in srgb, var(--mat-error) 18%, transparent)",
                "--borderColor-danger-emphasis": "var(--mat-error)",
                "--borderColor-danger-muted": "color-mix(in srgb, var(--mat-error) 45%, transparent)",
                "--fgColor-attention": "var(--mat-tertiary)",
                "--bgColor-attention-emphasis": "var(--mat-tertiary)",
                "--bgColor-attention-muted": "color-mix(in srgb, var(--mat-tertiary) 18%, transparent)",
                "--borderColor-attention-emphasis": "var(--mat-tertiary)",
                "--borderColor-attention-muted": "color-mix(in srgb, var(--mat-tertiary) 45%, transparent)",
                "--fgColor-severe": "var(--mat-tertiary)",
                "--bgColor-severe-emphasis": "var(--mat-tertiary)",
                "--bgColor-severe-muted": "color-mix(in srgb, var(--mat-tertiary) 18%, transparent)",
                "--borderColor-severe-emphasis": "var(--mat-tertiary)",
                "--borderColor-severe-muted": "color-mix(in srgb, var(--mat-tertiary) 45%, transparent)",
                "--fgColor-done": "var(--mat-tertiary)",
                "--bgColor-done-emphasis": "var(--mat-tertiary)",
                "--bgColor-done-muted": "color-mix(in srgb, var(--mat-tertiary) 18%, transparent)",
                "--borderColor-done-emphasis": "var(--mat-tertiary)",
                "--borderColor-done-muted": "color-mix(in srgb, var(--mat-tertiary) 45%, transparent)",
                "--fgColor-sponsors": "var(--mat-tertiary)",
                "--bgColor-sponsors-emphasis": "var(--mat-tertiary)",
                "--bgColor-sponsors-muted": "color-mix(in srgb, var(--mat-tertiary) 18%, transparent)",
                "--borderColor-sponsors-emphasis": "var(--mat-tertiary)",
                "--borderColor-sponsors-muted": "color-mix(in srgb, var(--mat-tertiary) 45%, transparent)",
                "--button-primary-bgColor-rest": "var(--mat-primary)",
                "--button-primary-bgColor-hover": "color-mix(in srgb, var(--mat-primary) 88%, var(--mat-on-surface) 12%)",
                "--button-primary-bgColor-active": "color-mix(in srgb, var(--mat-primary) 80%, var(--mat-on-surface) 20%)",
                "--button-primary-bgColor-disabled": "color-mix(in srgb, var(--mat-primary) 45%, transparent)",
                "--button-primary-fgColor-rest": "var(--mat-on-primary)",
                "--button-primary-fgColor-disabled": "color-mix(in srgb, var(--mat-on-primary) 55%, transparent)",
                "--button-primary-borderColor-rest": "color-mix(in srgb, var(--mat-primary) 70%, var(--mat-on-surface) 30%)",
                "--button-primary-borderColor-hover": "color-mix(in srgb, var(--mat-primary) 62%, var(--mat-on-surface) 38%)",
                "--button-primary-borderColor-active": "color-mix(in srgb, var(--mat-primary) 55%, var(--mat-on-surface) 45%)",
                "--button-primary-borderColor-disabled": "transparent",
                "--button-primary-shadow-selected": "0px 0px 0px 0px transparent",
                "--button-default-bgColor-rest": "var(--mat-surface-container)",
                "--button-default-bgColor-hover": "var(--mat-surface-container-high)",
                "--button-default-bgColor-active": "var(--mat-surface-container-highest)",
                "--button-default-bgColor-disabled": "var(--mat-surface-container-low)",
                "--button-default-fgColor-rest": "var(--mat-on-surface)",
                "--button-default-borderColor-rest": "var(--mat-outline-variant)",
                "--button-default-borderColor-hover": "var(--mat-outline)",
                "--button-default-borderColor-active": "var(--mat-outline)",
                "--button-default-shadow-resting": "0px 0px 0px 0px transparent",
                "--button-outline-fgColor-rest": "var(--mat-primary)",
                "--button-outline-fgColor-hover": "var(--mat-primary)",
                "--button-outline-fgColor-disabled": "color-mix(in srgb, var(--mat-primary) 45%, transparent)",
                "--button-outline-fgColor-active": "var(--mat-on-primary)",
                "--button-outline-bgColor-rest": "transparent",
                "--button-outline-bgColor-hover": "color-mix(in srgb, var(--mat-primary) 12%, transparent)",
                "--button-outline-bgColor-active": "var(--mat-primary)",
                "--button-outline-bgColor-disabled": "transparent",
                "--button-outline-shadow-selected": "0px 0px 0px 0px transparent",
                "--button-danger-fgColor-rest": "var(--mat-error)",
                "--button-danger-fgColor-hover": "var(--mat-on-error)",
                "--button-danger-fgColor-active": "var(--mat-on-error)",
                "--button-danger-fgColor-disabled": "color-mix(in srgb, var(--mat-error) 45%, transparent)",
                "--button-danger-bgColor-rest": "transparent",
                "--button-danger-bgColor-hover": "var(--mat-error)",
                "--button-danger-bgColor-active": "color-mix(in srgb, var(--mat-error) 85%, var(--mat-on-surface) 15%)",
                "--button-danger-bgColor-disabled": "transparent",
                "--button-danger-borderColor-rest": "color-mix(in srgb, var(--mat-error) 60%, transparent)",
                "--button-danger-borderColor-hover": "var(--mat-error)",
                "--button-danger-borderColor-active": "var(--mat-error)",
                "--button-danger-iconColor-rest": "var(--mat-error)",
                "--button-danger-iconColor-hover": "var(--mat-on-error)",
                "--button-danger-shadow-selected": "0px 0px 0px 0px transparent",
                "--button-inactive-bgColor": "transparent",
                "--button-inactive-fgColor": "var(--mat-on-surface-variant)",
                "--button-invisible-bgColor-rest": "transparent",
                "--button-invisible-bgColor-hover": "color-mix(in srgb, var(--mat-on-surface) 8%, transparent)",
                "--button-invisible-bgColor-active": "color-mix(in srgb, var(--mat-on-surface) 12%, transparent)",
                "--button-invisible-bgColor-disabled": "transparent",
                "--button-invisible-iconColor-rest": "var(--mat-on-surface-variant)",
                "--button-invisible-iconColor-hover": "var(--mat-on-surface)",
                "--button-invisible-iconColor-disabled": "color-mix(in srgb, var(--mat-on-surface-variant) 45%, transparent)",
                "--button-invisible-fgColor-rest": "var(--mat-on-surface)",
                "--button-invisible-fgColor-hover": "var(--mat-on-surface)",
                "--button-invisible-fgColor-active": "var(--mat-on-surface)",
                "--button-invisible-fgColor-disabled": "color-mix(in srgb, var(--mat-on-surface) 45%, transparent)",
                "--button-invisible-borderColor-rest": "transparent",
                "--button-invisible-borderColor-hover": "transparent",
                "--button-invisible-borderColor-active": "transparent",
                "--button-invisible-borderColor-disabled": "transparent",
                "--control-bgColor-rest": "var(--mat-surface-container)",
                "--control-bgColor-hover": "var(--mat-surface-container-high)",
                "--control-bgColor-active": "var(--mat-surface-container-highest)",
                "--control-bgColor-disabled": "var(--mat-surface-container-low)",
                "--control-bgColor-selected": "var(--mat-surface-container-high)",
                "--control-fgColor-rest": "var(--mat-on-surface)",
                "--control-fgColor-placeholder": "var(--mat-on-surface-variant)",
                "--control-fgColor-disabled": "color-mix(in srgb, var(--mat-on-surface) 45%, transparent)",
                "--control-iconColor-rest": "var(--mat-on-surface-variant)",
                "--control-borderColor-rest": "var(--mat-outline-variant)",
                "--control-borderColor-emphasis": "var(--mat-outline)",
                "--control-borderColor-selected": "var(--mat-primary)",
                "--control-borderColor-disabled": "color-mix(in srgb, var(--mat-outline) 25%, transparent)",
                "--control-checked-bgColor-rest": "var(--mat-primary)",
                "--control-checked-bgColor-hover": "color-mix(in srgb, var(--mat-primary) 88%, var(--mat-on-surface) 12%)",
                "--control-checked-bgColor-active": "color-mix(in srgb, var(--mat-primary) 80%, var(--mat-on-surface) 20%)",
                "--control-checked-bgColor-disabled": "color-mix(in srgb, var(--mat-primary) 45%, transparent)",
                "--control-checked-fgColor-rest": "var(--mat-on-primary)",
                "--control-checked-fgColor-disabled": "color-mix(in srgb, var(--mat-on-primary) 55%, transparent)",
                "--control-checked-borderColor-rest": "var(--mat-primary)",
                "--control-checked-borderColor-hover": "var(--mat-primary)",
                "--control-checked-borderColor-active": "var(--mat-primary)",
                "--control-checked-borderColor-disabled": "transparent",
                "--controlTrack-bgColor-rest": "var(--mat-surface-container-high)",
                "--controlTrack-bgColor-hover": "var(--mat-surface-container-highest)",
                "--controlTrack-bgColor-active": "var(--mat-surface-container-highest)",
                "--controlTrack-bgColor-disabled": "var(--mat-surface-container-low)",
                "--controlTrack-borderColor-rest": "var(--mat-outline-variant)",
                "--controlTrack-borderColor-disabled": "color-mix(in srgb, var(--mat-outline) 25%, transparent)",
                "--controlTrack-fgColor-rest": "var(--mat-on-surface-variant)",
                "--controlTrack-fgColor-disabled": "color-mix(in srgb, var(--mat-on-surface-variant) 45%, transparent)"
            }
        }
    ]
}
