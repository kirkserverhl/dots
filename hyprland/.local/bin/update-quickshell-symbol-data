#!/usr/bin/env bash
set -euo pipefail

data_dir="${XDG_DATA_HOME:-$HOME/.local/share}/quickshell/symbol-picker"
emoji_url="https://raw.githubusercontent.com/milesj/emojibase/master/packages/data/en/compact.raw.json"
nerd_font_url="https://raw.githubusercontent.com/ryanoasis/nerd-fonts/master/glyphnames.json"
max_age_seconds=$((7 * 24 * 60 * 60))
quiet=false
force=false

log() {
    if [[ "$quiet" == false ]]; then
        printf '%s\n' "$1"
    fi
}

usage() {
    cat <<'EOF'
Usage: update-quickshell-symbol-data [--force] [--quiet]

Downloads or refreshes the emoji and Nerd Font symbol datasets used by Quickshell.
EOF
}

file_age_seconds() {
    local path="$1"
    if [[ ! -f "$path" ]]; then
        printf '%s\n' "-1"
        return 0
    fi

    local now mtime
    now=$(date +%s)
    mtime=$(stat -c %Y "$path")
    printf '%s\n' "$((now - mtime))"
}

download_if_needed() {
    local url="$1"
    local path="$2"
    local label="$3"
    local age

    age=$(file_age_seconds "$path")
    if [[ "$force" == false && "$age" != "-1" && "$age" -lt "$max_age_seconds" ]]; then
        return 0
    fi

    local tmp
    tmp=$(mktemp)
    if curl -fsSL --retry 3 --connect-timeout 10 "$url" -o "$tmp"; then
        if [[ ! -s "$tmp" ]]; then
            rm -f "$tmp"
            printf '%s\n' "update-quickshell-symbol-data: downloaded empty $label payload" >&2
            return 1
        fi

        mv "$tmp" "$path"
        log "Updated $label data"
        return 0
    fi

    rm -f "$tmp"
    if [[ -f "$path" ]]; then
        printf '%s\n' "update-quickshell-symbol-data: failed to refresh $label, keeping existing file" >&2
        return 0
    fi

    printf '%s\n' "update-quickshell-symbol-data: failed to download required $label data" >&2
    return 1
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --force)
            force=true
            ;;
        --quiet)
            quiet=true
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            printf '%s\n' "Unknown option: $1" >&2
            usage >&2
            exit 1
            ;;
    esac
    shift
done

mkdir -p "$data_dir"
download_if_needed "$emoji_url" "$data_dir/emoji.json" "emoji"
download_if_needed "$nerd_font_url" "$data_dir/nerd-font-icons.json" "Nerd Font"
